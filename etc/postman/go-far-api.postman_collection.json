            "description": "Get a user by their ID"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "cache-control",
                "value": "must-revalidate"
              },
              {
                "key": "x-app-lang",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users?name=&email=&min_age=&max_age=&page=1&page_size=10&sort_by=created_at&sort_dir=desc",
              "host": ["{{base_url}}"],
              "path": ["users"],
              "query": [
                {
                  "key": "name",
                  "value": "",
                  "description": "Filter by name"
                },
                {
                  "key": "email",
                  "value": "",
                  "description": "Filter by email"
                },
                {
                  "key": "min_age",
                  "value": "",
                  "description": "Minimum age"
                },
                {
                  "key": "max_age",
                  "value": "",
                  "description": "Maximum age"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "page_size",
                  "value": "10",
                  "description": "Page size"
                },
                {
                  "key": "sort_by",
                  "value": "created_at",
                  "description": "Sort by field"
                },
                {
                  "key": "sort_dir",
                  "value": "desc",
                  "description": "Sort direction (asc/desc)"
                }
              ]
            },
            "description": "Get a paginated list of users with optional filters"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-app-lang",
                "value": "en"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"age\": 31,\n  \"role\": \"admin\",\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}"]
            },
            "description": "Update an existing user"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
