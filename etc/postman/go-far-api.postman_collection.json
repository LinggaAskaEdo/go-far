                "key": "x-app-lang",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}"]
            },
            "description": "Delete a user by ID"
          }
        }
      ]
    },
